generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  employeeId String?  @unique
  name       String
  email      String   @unique
  password   String
  role       Role     @default(WAITER)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  orders     Order[]

  @@index([email])
  @@map("users")
}

model Table {
  id          String      @id @default(uuid())
  tableNumber String      @unique
  capacity    Int
  zone        String
  qrCode      String?
  status      TableStatus @default(AVAILABLE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@map("tables")
}

model Category {
  id          String  @id @default(uuid())
  name        String  @unique
  icon        String?
  description String?
  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  foods Food[]

  @@map("categories")
}

model Food {
  id          String           @id @default(uuid())
  name        String
  description String?
  price       Decimal          @db.Decimal(10, 2)
  image       String?
  isAvailable Boolean          @default(true)
  categoryId  String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  category    Category         @relation(fields: [categoryId], references: [id])
  ingredients FoodIngredient[]
  orderItems  OrderItem[]

  @@map("foods")
}

model Order {
  id         String      @id @default(uuid())
  tableId    String
  userId     String?
  status     OrderStatus @default(PENDING)
  notes      String?
  totalPrice Decimal     @default(0) @db.Decimal(10, 2)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  table      Table       @relation(fields: [tableId], references: [id])
  user       User?       @relation(fields: [userId], references: [id])
  items      OrderItem[]
  payment    Payment?

  @@index([tableId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String   @id @default(uuid())
  orderId   String
  foodId    String
  foodName  String
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  subtotal  Decimal  @db.Decimal(10, 2)
  notes     String?
  createdAt DateTime @default(now())
  food      Food     @relation(fields: [foodId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([foodId])
  @@map("orderItems")
}

model Payment {
  id        String        @id @default(uuid())
  orderId   String        @unique
  amount    Decimal       @db.Decimal(10, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  paidAt    DateTime?
  createdAt DateTime      @default(now())
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model Ingredient {
  id        String           @id @default(uuid())
  name      String
  stock     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  foods     FoodIngredient[]

  @@map("ingredients")
}

model FoodIngredient {
  id           String     @id @default(uuid())
  foodId       String
  ingredientId String
  quantity     Int
  food         Food       @relation(fields: [foodId], references: [id])
  ingredient   Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([foodId])
  @@index([ingredientId])
  @@map("foodIngredients")
}

enum Role {
  ADMIN
  CHEF
  WAITER
  CASHIER
}

enum OrderStatus {
  PENDING
  COOKING
  READY
  SERVED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  KHQR
  ABA
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}
